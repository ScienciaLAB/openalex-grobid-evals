# Configuration for the OpenAlex -> GROBID evaluation pipeline.
# Sourced by run_pipeline.sh. Values already set in the environment take precedence
# (the ${VAR:=default} pattern only fills in unset variables).

# contact email for the OpenAlex polite pool
: "${MAILTO:=luca@sciencialab.com}"; export MAILTO

# PDFs fetched per pipeline iteration
: "${BATCH_SIZE:=1000}"; export BATCH_SIZE

# max parallel requests (downloads AND grobid calls)
: "${WORKERS:=3}"; export WORKERS

# where the GROBID server listens
: "${GROBID_URL:=http://localhost:8070}"; export GROBID_URL

# PDF retention after processing: all | flagged | none
: "${KEEP_PDFS:=flagged}"; export KEEP_PDFS

# where setup_grobid.sh clones/builds GROBID
: "${GROBID_HOME_DIR:=$HOME/grobid-eval/grobid}"; export GROBID_HOME_DIR
